{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#ffffff",
          "properties": {
            "display_host": false,
            "template": " \u25b2 {{ if .SSHSession }} \uf817 {{ end }}{{ .UserName }}"
          },
          "style": "powerline",
          "type": "session"
        },
        {
          "foreground": "#ffffff",
          "properties": {
            "style": "folder",
            "template": " {{ if ne .Path \"~\" }}- {{end}}{{ .Path }} "
          },
          "style": "powerline",
          "type": "path"
        },
        {
          "foreground": "#43CCEA",
          "properties": {
            "branch_icon": "",
            "template": "[{{ .HEAD }}] "
          },
          "style": "powerline",
          "type": "git"
        },
        {
          "foreground": "#ffffff",
          "properties": {
            "template": ": "
          },
          "style": "powerline",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 1
}